generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum ApptStatus {
  booked
  cancelled
  rescheduled
  completed
}

enum Outcome {
  booked
  cancelled
  no_action
  abandoned
}

enum Role {
  user
  agent
}

model Appointment {
  id               String     @id @default(cuid())
  callerName       String
  email            String
  phone            String
  vehicle          String
  service          String
  date             String
  time             String
  status           ApptStatus @default(booked)
  confirmationCode String     @unique
  googleEventId    String
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model CallSession {
  id              String            @id @default(cuid())
  roomName        String
  startedAt       DateTime          @default(now())
  endedAt         DateTime?
  outcome         Outcome           @default(no_action)
  durationSeconds Int?
  transcript      TranscriptEntry[]
}

model TranscriptEntry {
  id        String      @id @default(cuid())
  sessionId String
  session   CallSession @relation(fields: [sessionId], references: [id])
  role      Role
  content   String
  timestamp DateTime    @default(now())
}
